/*
Este script ha sido desarrollado con el objetivo de analizar el dataset de partida.
En este caso, la información de origen ya se encontraba limpia, lo que permite centrarse directamente en su exploración y en la obtención de los primeros insights.
Con el objetivo final de crear un dashboard, se aprovecha este proceso para generar nuevas columnas que permitan categorizar los productos y facilitar así el trabajo posterior en herramientas de visualización.
El script está diseñado para ser reproducible y mantenible, siguiendo una lógica estructurada y documentada en cada sección.
Microsoft SQL Server es el sistema utilizado.
*/

-- A tiempo vs retrasos vs total

SELECT 
    SUM(CASE WHEN on_time=0 THEN 1 ELSE 0 END) AS on_time,
    SUM(on_time) AS not_on_time,
    COUNT(*) AS total_shippings
FROM shipping;


-- Retrasos por bloque

SELECT 
    warehouse_block, 
    SUM(CASE WHEN on_time=1 THEN n_products ELSE 0 END) not_on_time_warehouse_block,
    SUM(CASE WHEN on_time=0 THEN n_products ELSE 0 END) on_time_warehouse_block,
    CAST(ROUND(100.0*SUM(CASE WHEN on_time=1 THEN n_products ELSE 0 END)/SUM(n_products),2) AS DECIMAL(10,2)) delays_percentage_warehouse_block
FROM (
    SELECT 
        warehouse_block, 
        on_time, 
        COUNT(*) n_products
    FROM shipping
    GROUP BY warehouse_block, on_time
    ) AS sub
GROUP BY warehouse_block
ORDER BY 4 DESC;


-- Retrasos por modo de envio

SELECT 
    mode, 
    SUM(CASE WHEN on_time=1 THEN n_products ELSE 0 END) not_on_time_mode,
    SUM(CASE WHEN on_time=0 THEN n_products ELSE 0 END) on_time_mode,
    CAST(ROUND(100.0*SUM(CASE WHEN on_time=1 THEN n_products ELSE 0 END)/SUM(n_products),2) AS DECIMAL(10,2)) delays_percentage_mode
FROM (
    SELECT 
        mode, 
        on_time, 
        COUNT(*) n_products 
    FROM shipping
    GROUP BY mode, on_time
    ) AS sub
GROUP BY mode
ORDER BY 4 DESC;


-- Retrasos por precio del producto

SELECT
    quartil_cost,
    SUM(on_time) AS delays_cost,
    SUM(CASE WHEN on_time=0 THEN 1 ELSE 0 END) on_time_cost,
    COUNT(*) AS n_product,
    AVG(cost) AS avg_cost,
    MIN(cost) AS min_cost,
    MAX(cost) AS max_cost
FROM (
    SELECT 
        cost,
        on_time,
        NTILE(4) OVER (ORDER BY cost) AS quartil_cost
    FROM shipping
    ) AS sub
GROUP BY quartil_cost
ORDER BY 2 DESC;


-- Añado el cuartil según el coste para cada envío

ALTER TABLE shipping
ADD quartil_cost nvarchar(255);

UPDATE s
SET quartil_cost = q.quartil
FROM shipping s
JOIN (
    SELECT 
        id,
        NTILE(4) OVER (ORDER BY cost) AS quartil
    FROM shipping
    ) q
    ON s.id = q.id;


-- Retrasos por descuento 

SELECT 
    discount, 
    SUM(CASE WHEN on_time=1 THEN n_products ELSE 0 END) not_on_time_discount,
    SUM(CASE WHEN on_time=0 THEN n_products ELSE 0 END) on_time_discount,
    CAST(ROUND(100.0*SUM(CASE WHEN on_time=1 THEN n_products ELSE 0 END)/SUM(n_products),2) AS DECIMAL(10,2)) delays_percentage_discount
FROM (
    SELECT 
        discount, 
        on_time,
        COUNT(*) n_products 
    FROM shipping
    GROUP BY discount, on_time
    ) AS sub
GROUP BY discount
ORDER BY 4 DESC;


-- Retrasos por peso 

SELECT
    quartil_weight,
    SUM(on_time) AS delays_weight,
    SUM(CASE WHEN on_time=0 THEN 1 ELSE 0 END) on_time_cost,
    COUNT(*) AS n_product,
    AVG(weight) AS avg_weight,
    MIN(weight) AS min_weight,
    MAX(weight) AS max_weight
FROM (
    SELECT 
        weight,
        on_time,
        NTILE(4) OVER (ORDER BY cost) AS quartil_weight
    FROM shipping
    ) AS sub
GROUP BY quartil_weight
ORDER BY 2 DESC;


-- Añado el cuartil según el peso para cada envío

ALTER TABLE shipping
